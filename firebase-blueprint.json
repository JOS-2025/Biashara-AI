{
  "entities": {
    "transaction": {
      "title": "Transaction",
      "description": "A financial transaction representing a sale or an expense.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the transaction."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this transaction."
        },
        "type": {
          "type": "string",
          "enum": ["sale", "expense"],
          "description": "The type of transaction."
        },
        "amount": {
          "type": "number",
          "description": "The amount of the transaction in KES."
        },
        "category": {
          "type": "string",
          "description": "The category of the transaction (e.g., sales, other income, stock, rent, transport, salary, utilities, marketing, other)."
        },
        "description": {
          "type": "string",
          "description": "A description of the transaction."
        },
        "productId": {
          "type": "string",
          "description": "Optional ID of the product associated with this transaction."
        },
        "quantity": {
          "type": "number",
          "description": "Optional quantity of the product involved in this transaction."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the transaction was created."
        }
      },
      "required": ["userId", "type", "amount", "category", "description", "createdAt"]
    },
    "product": {
      "title": "Product",
      "description": "An item in the inventory.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the product."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this product."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "stock": {
          "type": "number",
          "description": "The current stock level of the product."
        },
        "totalSold": {
          "type": "number",
          "description": "Total quantity of this product sold."
        },
        "totalBought": {
          "type": "number",
          "description": "Total quantity of this product bought/restocked."
        },
        "unit": {
          "type": "string",
          "description": "The unit of measurement (e.g., kg, pieces, bags)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the product was created."
        }
      },
      "required": ["userId", "name", "stock", "totalSold", "totalBought", "createdAt"]
    },
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The user's profile photo URL."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role in the application."
        }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "transaction",
      "description": "Collection of all transactions."
    },
    "/products/{productId}": {
      "schema": "product",
      "description": "Collection of all products in the inventory."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of user profiles."
    }
  }
}
